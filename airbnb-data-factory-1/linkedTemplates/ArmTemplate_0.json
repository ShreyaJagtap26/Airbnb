		{
			"name": "[concat(parameters('factoryName'), '/BookingTransformation')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "BookingDataCosmosSource",
								"type": "DatasetReference"
							},
							"name": "BookingsourceCosmos"
						},
						{
							"dataset": {
								"referenceName": "BookingFactSynapse",
								"type": "DatasetReference"
							},
							"name": "SynapseBookingFct"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "BookingFactSynapse",
								"type": "DatasetReference"
							},
							"name": "synapseTarget"
						}
					],
					"transformations": [
						{
							"name": "DataQualityCheck"
						},
						{
							"name": "lookupforInsertUpdate"
						},
						{
							"name": "GenerateInsertUpdateFlag"
						},
						{
							"name": "FinalColumns"
						}
					],
					"scriptLines": [
						"source(output(",
						"          city as string,",
						"          channel as string,",
						"          nights as short,",
						"          checkout_date as date,",
						"          customer_id as short,",
						"          guests_adults as short,",
						"          listing_id as integer,",
						"          checkin_date as date,",
						"          booking_created_at as string,",
						"          device_type as string,",
						"          country_code as string,",
						"          cancellation_reason as string,",
						"          lead_time_days as short,",
						"          booking_id as string,",
						"          price_nightly as double,",
						"          guests_infants as integer,",
						"          status as string,",
						"          guests_children as integer,",
						"          currency as string,",
						"          total_amount as double,",
						"          updated_at as string,",
						"          cancellation_ts as string,",
						"          cleaning_fee as double",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     enableChangeFeed: true,",
						"     changeFeedStartFromTheBeginning: true,",
						"     format: 'document') ~> BookingsourceCosmos",
						"source(output(",
						"          booking_id as string,",
						"          customer_id as integer,",
						"          listing_id as string,",
						"          status as string,",
						"          booking_created_at as date,",
						"          checkin_date as date,",
						"          checkout_date as date,",
						"          nights as integer,",
						"          lead_time_days as integer,",
						"          guests_adults as integer,",
						"          guests_children as integer,",
						"          guests_infants as integer,",
						"          price_nightly as decimal(12,2),",
						"          cleaning_fee as decimal(12,2),",
						"          total_amount as decimal(14,2),",
						"          currency as string,",
						"          country_code as string,",
						"          city as string,",
						"          channel as string,",
						"          device_type as string,",
						"          cancellation_ts as timestamp,",
						"          cancellation_reason as string,",
						"          updated_at as timestamp",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     format: 'table',",
						"     staged: true) ~> SynapseBookingFct",
						"BookingsourceCosmos split(checkout_date < checkin_date,",
						"     disjoint: false) ~> DataQualityCheck@(BadRecords, AccepctedRecords)",
						"DataQualityCheck@AccepctedRecords, SynapseBookingFct lookup(DataQualityCheck@AccepctedRecords@booking_id == SynapseBookingFct@booking_id,",
						"     multiple: false,",
						"     pickup: 'first',",
						"     desc(SynapseBookingFct@updated_at, true),",
						"     broadcast: 'auto')~> lookupforInsertUpdate",
						"lookupforInsertUpdate alterRow(insertIf(isNull(SynapseBookingFct@booking_id)),",
						"     updateIf(not(isNull(SynapseBookingFct@booking_id)))) ~> GenerateInsertUpdateFlag",
						"GenerateInsertUpdateFlag select(mapColumn(",
						"          city = DataQualityCheck@AccepctedRecords@city,",
						"          channel = DataQualityCheck@AccepctedRecords@channel,",
						"          nights = DataQualityCheck@AccepctedRecords@nights,",
						"          checkout_date = DataQualityCheck@AccepctedRecords@checkout_date,",
						"          customer_id = DataQualityCheck@AccepctedRecords@customer_id,",
						"          guests_adults = DataQualityCheck@AccepctedRecords@guests_adults,",
						"          listing_id = DataQualityCheck@AccepctedRecords@listing_id,",
						"          checkin_date = DataQualityCheck@AccepctedRecords@checkin_date,",
						"          booking_created_at = DataQualityCheck@AccepctedRecords@booking_created_at,",
						"          device_type = DataQualityCheck@AccepctedRecords@device_type,",
						"          country_code = DataQualityCheck@AccepctedRecords@country_code,",
						"          cancellation_reason = DataQualityCheck@AccepctedRecords@cancellation_reason,",
						"          lead_time_days = DataQualityCheck@AccepctedRecords@lead_time_days,",
						"          booking_id = DataQualityCheck@AccepctedRecords@booking_id,",
						"          price_nightly = DataQualityCheck@AccepctedRecords@price_nightly,",
						"          guests_infants = DataQualityCheck@AccepctedRecords@guests_infants,",
						"          status = DataQualityCheck@AccepctedRecords@status,",
						"          guests_children = DataQualityCheck@AccepctedRecords@guests_children,",
						"          currency = DataQualityCheck@AccepctedRecords@currency,",
						"          total_amount = DataQualityCheck@AccepctedRecords@total_amount,",
						"          updated_at = DataQualityCheck@AccepctedRecords@updated_at,",
